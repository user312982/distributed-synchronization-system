# Node Configuration
NODE_ID=node1
NODE_HOST=0.0.0.0
NODE_PORT=8001
NODE_PEERS=node2:8002,node3:8003

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Raft Configuration
RAFT_ELECTION_TIMEOUT_MIN=150
RAFT_ELECTION_TIMEOUT_MAX=300
RAFT_HEARTBEAT_INTERVAL=50
RAFT_LOG_COMPACTION_THRESHOLD=1000

# Queue Configuration
