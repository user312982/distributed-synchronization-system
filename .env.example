QUEUE_DELIVERY_TIMEOUT=30
QUEUE_MAX_RETRY=5
QUEUE_VIRTUAL_NODES=150

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_PROTOCOL=MESI
CACHE_REPLACEMENT=LRU

# Metrics & Monitoring
METRICS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
